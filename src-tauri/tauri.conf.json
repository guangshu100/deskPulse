{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EyeCare",
  "version": "1.0.0",
  "identifier": "com.eyecare.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EyeCare",
        "label": "main",
        "width": 420,
        "height": 680,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*; img-src 'self' https://* data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "webview": {
      "dataDirectory": "eyecare-webview"
    }
  }
}